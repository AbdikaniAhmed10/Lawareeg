# Copy to .env.docker and fill secrets before `docker compose up`
# NEVER commit .env.docker with real passwords.

APP_NAME=Lawareeg
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:GENERATE_ME
APP_URL=https://lawareeg.yourdomain.com
FRONTEND_URL=https://lawareeg.yourdomain.com

# Port exposed on Contabo localhost for host reverse proxy
LAWAREEG_HTTP_PORT=8088

# Frontend build-time API base (same host /api when using combined nginx)
VITE_API_URL=https://lawareeg.yourdomain.com/api

DB_DATABASE=lawareeg
DB_USERNAME=lawareeg
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

MAIL_MAILER=smtp
# Leave empty/null for Gmail port 587 (STARTTLS). Never set MAIL_SCHEME=smtp.
MAIL_SCHEME=
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=lawareeg10@gmail.com
# Gmail App Password (16 chars) — NOT your normal Gmail login password.
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=lawareeg10@gmail.com
MAIL_FROM_NAME=Lawareeg

# Built-in admin (created by: php artisan db:seed)
# Do NOT use demo passwords in production.
ADMIN_NAME=Lawareeg Admin
ADMIN_EMAIL=admin@lawareeg.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# Set true only for local demos (buyer/seller fake listings). Leave false online.
SEED_DEMO=false

LOG_CHANNEL=stderr
LOG_LEVEL=warning
